FROM python:3.11-slim

WORKDIR /app

ENV HF_HOME=/app/models

RUN pip install --no-cache-dir \
    fastapi \
    "uvicorn[standard]" \
    sentence-transformers

# Bake model weights into the image layer at build time.
# No network dependency at runtime.
RUN python -c "from sentence_transformers import SentenceTransformer; SentenceTransformer('intfloat/e5-base', cache_folder='/app/models')"

COPY embed/main.py ./main.py

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8080"]
